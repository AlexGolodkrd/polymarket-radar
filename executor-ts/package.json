{
  "name": "@plan-kapkan/executor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript executor layer for plan-kapkan radar (Phase TS-1 skeleton).",
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "biome check src tests",
    "format": "biome format --write src tests"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "pino-pretty": "^11.0.0",
    "socket.io-client": "^4.8.0",
    "undici": "^6.25.0",
    "viem": "^2.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
