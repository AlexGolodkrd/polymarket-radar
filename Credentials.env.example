# Credentials.env.example — template for plan-kapkan operator setup.
#
# DO NOT COMMIT THE REAL Credentials.env. This template lives in git
# so the operator (or a future bot) can see what env vars are read
# without ever exposing secrets.
#
# Copy:    cp Credentials.env.example Credentials.env
# Edit:    fill in real values for the bots you actually fund
# Reload:  docker compose restart radar executor-ts (on VPS)
#
# All env vars below are documented one-per-line so a future audit can
# `grep` them mechanically. Comments next to each describe REQUIRED vs
# OPTIONAL and which subsystem reads it.

# ──────────────────────────────────────────────────────────────────────
# GitHub Personal Access Token — used by deploy.yml hooks and the
# session agent for opening PRs via REST API. Scoped to repo:write.
# Operator-set; rotate every 90d or after suspected leak.
# ──────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_REPLACE_ME_REPO_WRITE_TOKEN

# ──────────────────────────────────────────────────────────────────────
# Bot wallets — 6 slots hardcoded. For single-bot pilot only fill bot1.
# Set BOT_COUNT=1 below to skip bot2-6 in the coordinator.
#
# Each bot needs: address (public, 0x40-hex) + private key (64-hex,
# no 0x prefix). PRIVATE_KEY is read once at boot, registered in a
# module-scoped Map, and NEVER serialized — even console.log(wallet)
# can't leak it.
# ──────────────────────────────────────────────────────────────────────
BOT1_ETH_ADDRESS=0xREPLACE_ME
BOT1_PRIVATE_KEY=REPLACE_ME_64_HEX_NO_0X_PREFIX
BOT2_ETH_ADDRESS=
BOT2_PRIVATE_KEY=
BOT3_ETH_ADDRESS=
BOT3_PRIVATE_KEY=
BOT4_ETH_ADDRESS=
BOT4_PRIVATE_KEY=
BOT5_ETH_ADDRESS=
BOT5_PRIVATE_KEY=
BOT6_ETH_ADDRESS=
BOT6_PRIVATE_KEY=

# ──────────────────────────────────────────────────────────────────────
# Polymarket L2 credentials per bot — derived via
# `python Scripts/poly_derive_api_creds.py --bot bot{N}` (residential
# proxy required on operator's machine). One-time per bot.
#
# api_key = UUID, secret = base64, passphrase = random — all 3 needed
# for HMAC headers on /order, DELETE /order/{id}, /positions, user-WS.
# ──────────────────────────────────────────────────────────────────────
BOT1_POLY_API_KEY=
BOT1_POLY_SECRET=
BOT1_POLY_PASSPHRASE=
# (omit BOT2-6 entries here — fill same shape when ready)

# ──────────────────────────────────────────────────────────────────────
# Limitless Exchange — Trading-scope API token + HMAC secret.
# Obtained ONLY via limitless.exchange UI (Privy auth), NOT
# programmatically. One token per wallet; previous tokens auto-revoked
# when a new one is generated.
#
# Auth uses HMAC-SHA256 over canonical message
# `{ISO timestamp}\n{METHOD}\n{path?query}\n{body}`. Signer impls:
#   - Python: Scripts/limitless_hmac.py
#   - TS:     executor-ts/src/lib/limitless_hmac.ts
#
# Per-bot BOT{i}_LIMITLESS_API_* takes priority; global
# LIMITLESS_API_* used as fallback (typical for single-bot pilot).
# ──────────────────────────────────────────────────────────────────────
LIMITLESS_API_KEY=
LIMITLESS_API_SECRET=
# BOT1_LIMITLESS_API_KEY=     # only for multi-bot — overrides global
# BOT1_LIMITLESS_API_SECRET=  # only for multi-bot — overrides global

# ──────────────────────────────────────────────────────────────────────
# Coordinator / sizing config. Operator-tunable for single-bot pilot.
# ──────────────────────────────────────────────────────────────────────
BOT_COUNT=1                        # 1..6, defaults 6 (clamped if outside)
MIN_USDC_PER_BOT=5                 # coordinator skips bot if balance < this
MAX_PER_TRADE_USD=5                # per-leg cap (per atomic.py); was 55
MIN_NET_PER_ARB_USD=0.50           # threshold for fire (net of fees)
DRY_RUN=1                          # 1 = paper, 0 = REAL MONEY. Default 1!
DEPTH_RECHECK_ENABLED=1
SLIPPAGE_TOLERANCE=0.005

# ──────────────────────────────────────────────────────────────────────
# Residential proxy (TS-5d) — required for order placement when
# DRY_RUN=0. Polymarket geoblocks datacenter IPs; Limitless rate-limits
# them. Set the URL when ready; the proxy_pool module + keepalive
# ticker handle everything else automatically.
# ──────────────────────────────────────────────────────────────────────
# PROXY_URL_DEFAULT=http://user:pass@residential.proxy:8080
# PROXY_URL_POLYMARKET=             # per-platform override
# PROXY_URL_LIMITLESS=
# PROXY_URL_SX=NONE                 # NONE = explicit direct (skip proxy for SX)
# PROXY_FALLBACK_TO_DIRECT=0        # NEVER 1 in real-mode
# PROXY_KEEPALIVE_INTERVAL_S=30     # ping interval to prevent IP rotation
# PROXY_STICKY_SESSION_PATTERN={platform}-{bot}

# ──────────────────────────────────────────────────────────────────────
# Platform toggles (off-by-default for safety).
# ──────────────────────────────────────────────────────────────────────
ENABLE_POLY=1
ENABLE_LIMITLESS=1
ENABLE_SX=1
ENABLE_KALSHI=0                    # Kalshi geo-blocked from non-US VPS
ENABLE_LIMITLESS_WS=0              # WS-only orderbook (TS-5a hardening)
LIMITLESS_WS_REQUIRED=0            # 1 = no REST fallback (after stability ok)
POLYMARKET_WS_REQUIRED=0           # 1 = same for Polymarket (TS-5c)

# ──────────────────────────────────────────────────────────────────────
# Limitless WS supervisor tuning (TS-5a). Operator only tweaks if
# residential proxy provider has unusual session rotation patterns.
# ──────────────────────────────────────────────────────────────────────
# LIMITLESS_WS_RECONNECT_ATTEMPTS=5
# LIMITLESS_WS_CONNECT_TIMEOUT=5
# LIMITLESS_WS_MAX_FAILS_BEFORE_PAUSE=10
# LIMITLESS_WS_LONG_PAUSE_S=300

# ──────────────────────────────────────────────────────────────────────
# Polymarket V2 contract addresses (rarely changed). Read by
# Scripts/polymarket_approve.py — keep aligned with live mainnet.
# ──────────────────────────────────────────────────────────────────────
# POLY_PUSD_ADDRESS=                # default in script
# POLY_EXCHANGE_STANDARD=
# POLY_EXCHANGE_NEGRISK=

# ──────────────────────────────────────────────────────────────────────
# Cold wallet address (TS-5b auto-sweep) — destination for excess
# USDC when bot balance > REBALANCE_HIGH_USDC. Optional; if unset
# auto-sweep is disabled.
# ──────────────────────────────────────────────────────────────────────
# COLD_WALLET_ADDRESS=0x...

# ──────────────────────────────────────────────────────────────────────
# OpenAI / Apify / external services — only if used by analytics.py
# tagging pipelines. Off by default; safe to leave blank.
# ──────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# APIFY_TOKEN=
