# Template for Credentials.env (NOT checked in — gitignored)
# Copy to Credentials.env and fill in values when ready.
# At minimum the radar runs without ANY of these set (dry-run mock pool).

# ── GitHub (already in CLAUDE.md procedure) ─────────────────────────
GITHUB_TOKEN=

# ── Phase 4: 6-bot wallet pool ─────────────────────────────────────
# Backend selection — 'local' reads from this file (default), 'windows_cred'
# uses Windows Credential Manager (Phase 6), 'aws' uses AWS Secrets Manager.
WALLET_BACKEND=local

# Cold storage address — destination for auto-sweep when a bot accumulates
# excess profit (Phase 5+). Optional.
COLD_WALLET_ADDRESS=

# Bot wallet addresses. Fill in 6 ETH/Polygon addresses; private keys
# can stay blank until Phase 5 graduation gate passes.
BOT1_ETH_ADDRESS=
BOT1_PRIVATE_KEY=
BOT2_ETH_ADDRESS=
BOT2_PRIVATE_KEY=
BOT3_ETH_ADDRESS=
BOT3_PRIVATE_KEY=
BOT4_ETH_ADDRESS=
BOT4_PRIVATE_KEY=
BOT5_ETH_ADDRESS=
BOT5_PRIVATE_KEY=
BOT6_ETH_ADDRESS=
BOT6_PRIVATE_KEY=

# ── Phase 6: VPS deployment ────────────────────────────────────────
# Polygon RPC URL for on-chain reads (USDC balances) and writes
# (rebalance transfers). Use Alchemy / Infura / Quicknode.
POLYGON_RPC_URL=

# AWS region for Secrets Manager (when WALLET_BACKEND=aws)
AWS_REGION=us-east-2

# ── Executor mode ──────────────────────────────────────────────────
# Default DRY_RUN=1 (dry-run only). Flip to 0 ONLY after Phase 5
# graduation gate (>=70% win rate, <=20% drift over 100 paper trades).
DRY_RUN=1

# ── Network safety (VPN kill switch Layer 3) ──────────────────────
# Comma-separated ISO-2 country codes from which the bot is allowed to
# trade. Bot looks up its own outbound IP every 60s; if country isn't
# in this list, all fires are BLOCKED (fail-safe).
#
# Set to the country you registered Polymarket from. Examples:
#   ALLOWED_COUNTRIES=GE              # only Georgia
#   ALLOWED_COUNTRIES=GE,AM,TR        # GE primary, AM/TR fallback in same region
#
# Leave EMPTY for local dev (skips check). Set on production VPS.
ALLOWED_COUNTRIES=

# Per-platform toggles. Set to 0 to skip a platform entirely (no fetches,
# no eval, no micro-loops). Default 1 (all enabled).
ENABLE_KALSHI=1
ENABLE_SX=1

# Polymarket main-scan pages (1 page = 500 events). Default 4 = 2000 events.
# When Kalshi/SX are disabled, can crank to 6-8 for wider Polymarket coverage.
POLY_MAIN_PAGES=4
